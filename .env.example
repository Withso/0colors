# ── Backend (packages/backend) ──
DATABASE_URL=postgresql://user:password@localhost:5432/zerocolors
PORT=4455
# Optional. Used by routes/cron.ts to gate the scheduled token-pull endpoint.
CRON_SECRET=

# ── Frontend (packages/frontend) — prefix with VITE_ ──
# Leave VITE_API_BASE_URL unset to use same-origin /api (the default once the
# backend serves the SPA in Phase 3). Set it only if you run the frontend on a
# different origin than the backend.
VITE_API_BASE_URL=

# ── Optional AI features ──
# Phase 1: read by packages/backend/src/routes/ai.ts. Omit any provider you
# don't use; AI features will simply be disabled if no provider key is set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
