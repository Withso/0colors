# ─────────────────────────────────────────────────────────────────────────────
# 0colors — environment variables
#
# On Railway: the template wires DATABASE_URL automatically via the Postgres
# plugin reference. Mark ADMIN_EMAIL / ADMIN_PASSWORD as user-supplied (with
# descriptions) so the deploy wizard prompts for them. AI keys are optional —
# leave any provider unset and that AI option is disabled in the UI.
#
# Locally: copy this file to .env and fill in DATABASE_URL.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──
DATABASE_URL=postgresql://user:password@localhost:5432/zerocolors

# Port the backend listens on. Railway injects $PORT automatically; the
# default below is only used in local development.
PORT=4455

# ── Optional: zero-touch admin seed on first boot ──
# If both are set AND no user has activated their account yet, the backend
# provisions the admin from these on startup, skipping the setup wizard.
# Leave blank to use the in-app /setup wizard instead.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Optional: AI features (each is independent) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Optional: Figma webhook signing ──
# Required only if you wire a Figma → 0colors webhook into routes/figma.ts.
FIGMA_WEBHOOK_SECRET=

# ── Optional: scheduled cron jobs ──
# Required only if you use the routes/cron.ts endpoints. On Railway, generate
# with ${{ secret(32) }} so each install gets a unique value.
CRON_SECRET=

# ── Frontend (packages/frontend) — only when running the SPA on a different
# origin than the backend. Leave blank for the standard single-service setup.
VITE_API_BASE_URL=
