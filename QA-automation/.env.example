# QA automation environment template
#
# Copy to .env only when you need local overrides for QA tooling.
# Do NOT commit real credentials or machine-specific values.

# Base URL for Playwright / local runner when targeting an already-running app.
# Default in the repo is http://localhost:3000
BASE_URL=http://localhost:3000

# Skip Playwright's built-in webServer when the app is already running.
# 1 = skip webServer, 0 = allow Playwright to start the app
PLAYWRIGHT_SKIP_WEB_SERVER=1

# Local-only QA runner port
QA_RUNNER_PORT=47841

# Optional manual cloud/auth smoke credentials
# Used only by optional legacy/manual specs, not by the default qa:full pipeline.
QA_TEST_EMAIL=
QA_TEST_PASSWORD=
