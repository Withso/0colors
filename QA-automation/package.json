{
  "name": "qa-automation-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Reusable Playwright QA harness + Vitest unit/integration tests; per-product tests live under projects/<name>/",
  "scripts": {
    "test": "playwright test",
    "test:vitest": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:domain": "vitest run --project=domain",
    "test:integration": "vitest run --project=integration",
    "test:0colors": "playwright test --project=0colors",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test",
    "report": "playwright show-report reports/html",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@supabase/supabase-js": "^2.49.4",
    "@testing-library/jest-dom": "^6.6.3",
    "fake-indexeddb": "^6.0.0",
    "hono": "^4.7.10",
    "jsdom": "^25.0.1",
    "msw": "^2.7.3",
    "typescript": "^5.7.3",
    "vitest": "^3.1.2",
    "zustand": "^5.0.3"
  }
}
