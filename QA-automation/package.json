{
  "name": "qa-automation-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Reusable Playwright QA harness; per-product tests live under projects/<name>/",
  "scripts": {
    "test": "playwright test",
    "test:0colors": "playwright test --project=0colors",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report reports/html",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "typescript": "^5.7.3"
  }
}
