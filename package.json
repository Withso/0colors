{
    "name": "0colors",
    "version": "1.0.0",
    "private": true,
    "description": "0colors – Full-stack monorepo (Backend + Frontend)",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently --names backend,frontend --prefix-colors cyan,magenta \"npm run dev -w @0colors/backend\" \"npm run dev -w @0colors/frontend\"",
        "dev:backend": "npm run dev -w @0colors/backend",
        "dev:frontend": "npm run dev -w @0colors/frontend",
        "build": "npm run build --workspaces --if-present",
        "build:backend": "npm run build -w @0colors/backend",
        "build:frontend": "npm run build -w @0colors/frontend",
        "typecheck": "npm run typecheck -w @0colors/backend",
        "start:backend": "npm run start -w @0colors/backend",
        "start:frontend": "npm run start -w @0colors/frontend"
    },
    "devDependencies": {
        "concurrently": "^9.1.2"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}