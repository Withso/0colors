{
    "name": "0colors",
    "version": "1.0.0",
    "private": true,
    "description": "0colors – Full-stack monorepo (Backend + Frontend)",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently --names backend,frontend --prefix-colors cyan,magenta \"npm run dev -w @0colors/backend\" \"npm run dev -w @0colors/frontend\"",
        "dev:qa": "concurrently --names backend,frontend,qa-runner --prefix-colors cyan,magenta,green \"npm run dev -w @0colors/backend\" \"npm run dev -w @0colors/frontend\" \"npm run qa:runner\"",
        "dev:backend": "npm run dev -w @0colors/backend",
        "dev:frontend": "npm run dev -w @0colors/frontend",
        "build": "npm run build --workspaces --if-present",
        "build:backend": "npm run build -w @0colors/backend",
        "build:frontend": "npm run build -w @0colors/frontend",
        "typecheck": "npm run typecheck -w @0colors/backend",
        "start:backend": "npm run start -w @0colors/backend",
        "start:frontend": "npm run start -w @0colors/frontend",
        "test:e2e": "node scripts/qa-e2e-run.mjs",
        "test:e2e:a11y": "npx playwright test -c playwright.a11y.config.ts",
        "test:e2e:headed": "QA_RUN_ID=manual-local npx playwright test --headed",
        "test:e2e:ui": "npx playwright test --ui",
        "test:e2e:install": "playwright install chromium",
        "test:domain": "node scripts/qa-vitest-layer.mjs domain",
        "test:property": "node scripts/qa-vitest-layer.mjs property",
        "test:component": "node scripts/qa-vitest-layer.mjs component",
        "test:integration": "node scripts/qa-vitest-layer.mjs integration",
        "qa:sync-report": "node scripts/sync-qa-dashboard.mjs",
        "qa:full": "node scripts/qa-full-run.mjs",
        "qa:runner": "node scripts/qa-local-runner.mjs",
        "test:e2e:report": "npm run test:e2e && npm run qa:sync-report",
        "test:unit": "node scripts/qa-vitest-layer.mjs unit",
        "test:qa:unit": "npx vitest run --config QA-automation/vitest.config.ts --project unit",
        "test:qa:domain": "npx vitest run --config QA-automation/vitest.config.ts --project domain",
        "test:qa:integration": "npx vitest run --config QA-automation/vitest.config.ts --project integration",
        "test:qa:e2e": "cd QA-automation && QA_PLAYWRIGHT_REPORT_FILE=reports/qa-e2e-results.json npx playwright test -c playwright.config.ts --project=0colors",
        "test:qa:smoke": "cd QA-automation && QA_PLAYWRIGHT_REPORT_FILE=reports/qa-smoke-results.json npx playwright test -c playwright.config.ts --project=0colors-smoke",
        "test:mutation": "stryker run"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.1",
        "@playwright/test": "^1.49.1",
        "@stryker-mutator/core": "^9.6.0",
        "@stryker-mutator/vitest-runner": "^9.6.0",
        "concurrently": "^9.1.2"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
